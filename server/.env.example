# Claude API key — powers the L3 analyst deep-dive and fundamental scoring.
# https://platform.claude.com  (the app runs without it; verdicts fall back to
# the deterministic engine when unset).
ANTHROPIC_API_KEY=

# Optional model overrides
# ANTHROPIC_DEEPDIVE_MODEL=claude-opus-4-8
# ANTHROPIC_ANALYST_MODEL=claude-sonnet-4-6

# Preferred market-data source (free key, 800 req/day). Yahoo hard-429s many
# networks; set this and it's used first. https://twelvedata.com/pricing (Basic/Free)
# TWELVE_DATA_API_KEY=

# Offline/demo data (never uses live Yahoo/Stooq). 1 = always fixtures.
# STOCK_FIXTURES=1
# Or fall back to demo data only when every live source is blocked:
# STOCK_FIXTURES_FALLBACK=1

# Scanner universe size — the top-N largest US names (default 100, fits the
# Twelve Data free tier: ~100 credits/day, cached 24h). Raise with a bigger plan.
# SCANNER_UNIVERSE_SIZE=100
# Scan the full S&P 500 from Wikipedia instead of the curated large-cap list
# (needs quota + patience — ~500 symbols paced at 8/min).
# SCANNER_FULL_UNIVERSE=1
# Scanner: opt in to per-ticker short-interest fetches (fragile + slow).
# SCANNER_SHORT_INTEREST=1

# Buy-zone alert emails via Resend (optional — alerts still show as "triggered"
# in the UI without these). https://resend.com
# RESEND_API_KEY=
# ALERT_EMAIL=you@example.com
# ALERT_FROM=Stock Checker <onboarding@resend.dev>

# SQLite location (defaults to server/stock-checker.db)
# DB_PATH=./stock-checker.db

PORT=3001
